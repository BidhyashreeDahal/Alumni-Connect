generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String
  role            Role

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  alumniProfile   AlumniProfile?
  studentProfile  StudentProfile?

  notesCreated    PrivateNote[]

  eventsCreated   Event[]
  eventRegistrations EventRegistration[]

  @@index([role])
}

model AlumniProfile {
  id             String        @id @default(cuid())
  userId         String?       @unique

  schoolEmail    String?       @unique
  personalEmail  String?       @unique

  firstName      String?
  lastName       String?

  program        String?
  graduationYear Int?

  jobTitle       String?
  company        String?

  skills         String[]      @default([])

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User?         @relation(fields: [userId], references: [id])

  mentorshipRequests MentorshipRequest[]

  @@index([program])
  @@index([graduationYear])
}

model StudentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique

  firstName      String?
  lastName       String?

  program        String?
  graduationYear Int?

  skills         String[] @default([])
  interests      String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])

  mentorshipRequests MentorshipRequest[]
}

model InviteToken {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  profileId   String
  profileType String   // "student" or "alumni"
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
}
enum ProfileType {
  student
  alumni
}

model PrivateNote {
  id          String   @id @default(cuid())

  profileId   String
  profileType ProfileType

  authorId    String
  content     String

  createdAt   DateTime @default(now())

  author      User     @relation(fields: [authorId], references: [id])

  @@index([profileId])
}

model MentorshipRequest {
  id        String            @id @default(cuid())

  studentId String
  alumniId  String

  message   String?

  status    MentorshipStatus  @default(pending)

  createdAt DateTime          @default(now())

  student   StudentProfile    @relation(fields: [studentId], references: [id])
  alumni    AlumniProfile     @relation(fields: [alumniId], references: [id])

  @@index([status])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String?
  eventDate   DateTime

  createdBy   String
  createdAt   DateTime @default(now())

  creator     User @relation(fields: [createdBy], references: [id])
  registrations EventRegistration[]
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  userId    String

  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

enum Role {
  admin
  faculty
  alumni
  student
}

enum MentorshipStatus {
  pending
  accepted
  declined
  completed
}