generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String
  role            Role
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  alumniProfile   AlumniProfile?
  studentProfile  StudentProfile?

  notesCreated    PrivateNote[]

  @@index([role])
}

model AlumniProfile {
  id             String        @id @default(cuid())
  userId         String?       @unique

  schoolEmail    String?       @unique
  personalEmail  String?       @unique

  firstName      String?
  lastName       String?

  program        String?
  graduationYear Int?

  jobTitle       String?
  company        String?

  skills         String[]      @default([])

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User?         @relation(fields: [userId], references: [id])

  invites        InviteToken[]
  notes          PrivateNote[]
  mentorshipRequests MentorshipRequest[]

  @@index([program])
  @@index([graduationYear])
}

model StudentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique

  firstName      String?
  lastName       String?

  program        String?
  graduationYear Int?

  skills         String[] @default([])
  interests      String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])

  mentorshipRequests MentorshipRequest[]
}

model InviteToken {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  profileId   String
  profileType String   // "student" or "alumni"
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
}

model PrivateNote {
  id         String        @id @default(cuid())
  profileId  String
  authorId   String

  content    String

  createdAt  DateTime      @default(now())

  profile    AlumniProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  author     User          @relation(fields: [authorId], references: [id])
}

model MentorshipRequest {
  id        String            @id @default(cuid())

  studentId String
  alumniId  String

  message   String?

  status    MentorshipStatus  @default(pending)

  createdAt DateTime          @default(now())

  student   StudentProfile    @relation(fields: [studentId], references: [id])
  alumni    AlumniProfile     @relation(fields: [alumniId], references: [id])

  @@index([status])
}

enum Role {
  admin
  faculty
  alumni
  student
}

enum MentorshipStatus {
  pending
  accepted
  declined
  completed
}