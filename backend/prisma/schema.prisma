generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  role               Role
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  alumniProfile      AlumniProfile?
  eventsCreated      Event[]
  eventRegistrations EventRegistration[]
  notesCreated       PrivateNote[]
  studentProfile     StudentProfile?

  @@index([role])
}

model AlumniProfile {
  id                 String              @id @default(cuid())
  schoolEmail        String?             @unique
  personalEmail      String?             @unique
  firstName          String?
  lastName           String?
  program            String?
  graduationYear     Int?
  jobTitle           String?
  company            String?
  skills             String[]            @default([])
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  userId             String?             @unique
  isArchived         Boolean             @default(false)
  user               User?               @relation(fields: [userId], references: [id])
  mentorshipRequests MentorshipRequest[]

  @@index([program])
  @@index([graduationYear])

  linkedinUrl    String?
  meetingLink    String?
}

model StudentProfile {
  id                 String              @id @default(cuid())
  userId             String?             @unique
  firstName          String?
  lastName           String?
  program            String?
  graduationYear     Int?
  skills             String[]            @default([])
  interests          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isArchived         Boolean             @default(false)

  mentorshipRequests MentorshipRequest[]

  user               User?               @relation(fields: [userId], references: [id])

  linkedinUrl        String?
}

model InviteToken {
  id          String    @id @default(cuid())
  profileId   String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  profileType String
}

model PrivateNote {
  id          String      @id @default(cuid())
  profileId   String
  authorId    String
  content     String
  createdAt   DateTime    @default(now())
  profileType ProfileType
  author      User        @relation(fields: [authorId], references: [id])

  @@index([profileId])
}

model MentorshipRequest {
  id        String           @id @default(cuid())
  studentId String
  alumniId  String
  message   String?
  status    MentorshipStatus @default(pending)
  createdAt DateTime         @default(now())
  alumni    AlumniProfile    @relation(fields: [alumniId], references: [id])
  student   StudentProfile   @relation(fields: [studentId], references: [id])

  @@index([status])
}

model Event {
  id            String              @id @default(cuid())
  title         String
  description   String?
  location      String?
  eventDate     DateTime
  createdBy     String
  createdAt     DateTime            @default(now())
  creator       User                @relation(fields: [createdBy], references: [id])
  registrations EventRegistration[]
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  status    RSVPStatus @default(registered)
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

enum ProfileType {
  student
  alumni
}

enum Role {
  admin
  faculty
  alumni
  student
}

enum MentorshipStatus {
  pending
  accepted
  declined
  cancelled
  completed
}

enum RSVPStatus {
  registered
  waitlisted
  cancelled
}
