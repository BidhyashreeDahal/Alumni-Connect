generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  role               Role
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  alumniProfile      AlumniProfile?
  eventsCreated      Event[]
  eventRegistrations EventRegistration[]
  notesCreated       PrivateNote[]
  studentProfile     StudentProfile?
  settings           UserSettings?
  announcements      Announcement[]
  auditLogs          AuditLog[]

  @@index([role])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  Role?
  action     String
  entityType String
  entityId   String?
  summary    String?
  metadata   Json?
  requestId  String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model Announcement {
  id             String   @id @default(cuid())
  title          String
  content        String
  creatorId      String
  targetRole     Role?
  targetProgram  String?
  targetGradYear Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([targetRole])
  @@index([targetProgram])
  @@index([targetGradYear])
  @@index([creatorId])
  @@index([createdAt])
}

model AlumniProfile {
  id                 String              @id @default(cuid())
  schoolEmail        String?             @unique
  personalEmail      String?             @unique
  firstName          String?
  lastName           String?
  program            String?
  graduationYear     Int?
  jobTitle           String?
  company            String?
  skills             String[]            @default([])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime            @updatedAt
  userId             String?             @unique
  isArchived         Boolean             @default(false)
  user               User?               @relation(fields: [userId], references: [id])
  mentorshipRequests MentorshipRequest[]

  linkedinUrl String?
  meetingLink String?

  @@index([program])
  @@index([graduationYear])
}

model StudentProfile {
  id             String   @id @default(cuid())
  userId         String?  @unique
  schoolEmail    String?  @unique
  personalEmail  String?  @unique
  firstName      String?
  lastName       String?
  program        String?
  graduationYear Int?
  skills         String[] @default([])
  interests      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isArchived     Boolean  @default(false)

  mentorshipRequests MentorshipRequest[]

  user User? @relation(fields: [userId], references: [id])

  linkedinUrl String?
}

model InviteToken {
  id          String    @id @default(cuid())
  profileId   String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  profileType String
}

model PrivateNote {
  id          String      @id @default(cuid())
  profileId   String
  authorId    String
  content     String
  createdAt   DateTime    @default(now())
  profileType ProfileType
  author      User        @relation(fields: [authorId], references: [id])

  @@index([profileId])
}

model MentorshipRequest {
  id        String           @id @default(cuid())
  studentId String
  alumniId  String
  message   String?
  status    MentorshipStatus @default(pending)
  createdAt DateTime         @default(now())
  alumni    AlumniProfile    @relation(fields: [alumniId], references: [id])
  student   StudentProfile   @relation(fields: [studentId], references: [id])

  @@index([status])
}

model Event {
  id             String              @id @default(cuid())
  title          String
  description    String?
  location       String?
  eventDate      DateTime
  targetAudience String              @default("all")
  createdBy      String
  createdAt      DateTime            @default(now())
  creator        User                @relation(fields: [createdBy], references: [id])
  registrations  EventRegistration[]
}

model EventRegistration {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  status    RSVPStatus @default(registered)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model UserSettings {
  id                 String            @id @default(cuid())
  userId             String            @unique
  profileVisibility  ProfileVisibility @default(students_only)
  emailMentorship    Boolean           @default(true)
  emailEvents        Boolean           @default(true)
  emailAnnouncements Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProfileVisibility {
  public
  students_only
  hidden
}

enum RSVPStatus {
  registered
  waitlisted
  cancelled
}

// enum AudienceType {
//   all
//   student
//   alumni
// }

enum ProfileType {
  student
  alumni
}

enum Role {
  admin
  faculty
  alumni
  student
}

enum MentorshipStatus {
  pending
  accepted
  declined
  cancelled
  completed
}
